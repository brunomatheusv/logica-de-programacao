algoritmo "SomaProcedimento"
var
   X, Y: inteiro
Procedimento Soma(A, B: inteiro)
inicio
      Escreval("Recebi o valor de ",A)
      Escreval("Recebi o valor de ",B)
      Escreval("A soma entre os dois números é ", A+B)
FimProcedimento
inicio
      X <- 5
      Y <- 3
      Soma(X, Y)
fimalgoritmo